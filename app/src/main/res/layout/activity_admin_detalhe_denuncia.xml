<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    tools:context=".AdminDetalheDenunciaActivity">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A3A5C"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="48dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <!-- TOPO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- BOTÃO VOLTAR -->
            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="#29496B"
                android:padding="10dp"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#FFFFFF" />

            <!-- TÍTULOS -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 Detalhe da Denúncia"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visualizar e gerenciar ocorrência"
                    android:textColor="#B8C7D9"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="150dp"
        android:layout_marginBottom="90dp"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════ CARD: INFORMAÇÕES GERAIS ═══════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- SEÇÃO TÍTULO -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📄 Informações Gerais"
                        android:textColor="#1A3A5C"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="14dp" />

                    <!-- TIPO -->
                    <TextView
                        android:id="@+id/textTipo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕳️ Buraco na via"
                        android:textColor="#1A3A5C"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- CIDADÃO -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Cidadão:"
                            android:textColor="#5F6F81"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textCidadao"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="João Silva"
                            android:textColor="#5F6F81"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- DATA -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Data:"
                            android:textColor="#5F6F81"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textData"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="28/05/2026"
                            android:textColor="#5F6F81"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- DESCRIÇÃO -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Descrição:"
                        android:textColor="#1A3A5C"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textDescricao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Existe um buraco muito grande na avenida causando risco aos motoristas. O buraco tem aproximadamente 50cm de diâmetro e está localizado na faixa da direita, próximo ao meio-fio."
                        android:textColor="#5F6F81"
                        android:textSize="14sp"
                        android:lineSpacingExtra="2dp" />

                    <!-- STATUS ATUAL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Status atual:"
                        android:textColor="#1A3A5C"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="#FFF3D6"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp">

                        <View
                            android:id="@+id/dotStatus"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="#F5A623" />

                        <TextView
                            android:id="@+id/textStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="EM ANÁLISE"
                            android:textColor="#F5A623"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ═══════════════ CARD: LOCALIZAÇÃO ═══════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Localização"
                        android:textColor="#1A3A5C"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textEndereco"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Carregando endereço..."
                        android:textColor="#5F6F81"
                        android:textSize="13sp" />

                    <!-- MAPA -->
                    <org.osmdroid.views.MapView
                        android:id="@+id/mapMini"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ═══════════════ CARD: FOTOS ═══════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷 Fotos da Denúncia"
                        android:textColor="#1A3A5C"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="140dp"
                                android:layout_height="140dp"
                                android:layout_marginEnd="12dp"
                                android:background="#D9E2EC"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_launcher_background" />

                            <ImageView
                                android:layout_width="140dp"
                                android:layout_height="140dp"
                                android:layout_marginEnd="12dp"
                                android:background="#D9E2EC"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_launcher_background" />

                        </LinearLayout>

                    </HorizontalScrollView>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ═══════════════ CARD: ALTERAR STATUS ═══════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✏️ Alterar Status"
                        android:textColor="#1A3A5C"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selecione o novo status da denúncia:"
                        android:textColor="#5F6F81"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerStatus"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="#F7F9FC"
                        android:padding="12dp"
                        android:elevation="2dp"
                        android:entries="@array/status_denuncia" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonSalvarStatus"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:text="💾 Salvar Status"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="#1A3A5C"
                        app:cornerRadius="14dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ═══════════════ CARD: DEVOLUTIVA ═══════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDevolutiva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝 Devolutiva ao Cidadão"
                        android:textColor="#1A3A5C"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Escreva uma resposta para informar o cidadão sobre a resolução do problema:"
                        android:textColor="#5F6F81"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/editDevolutiva"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="#F7F9FC"
                        android:gravity="top"
                        android:hint="Ex: O buraco foi reparado pela equipe de manutenção no dia 01/06/2026..."
                        android:inputType="textMultiLine"
                        android:padding="14dp"
                        android:textColor="#000000"
                        android:textColorHint="#9AA5B1"
                        android:textSize="14sp"
                        android:elevation="2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonEnviarDevolutiva"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:text="📨 Enviar Devolutiva"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="#27AE60"
                        app:cornerRadius="14dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- BARRA INFERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonVoltarLista"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="← Voltar"
            android:textColor="#1A3A5C"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#DCE6F2"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSalvarAlteracoes"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="💾 Salvar Tudo"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#1A3A5C"
            app:cornerRadius="14dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
