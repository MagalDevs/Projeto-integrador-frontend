<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    tools:context=".NovaDenunciaActivity">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A3A5C"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="48dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="#F5A623"
                android:gravity="center"
                android:text="🚨"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Nova Denúncia"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ajude a melhorar sua cidade reportando problemas urbanos"
            android:textColor="#D6E4F0"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="170dp"
        android:layout_marginBottom="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TIPO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo da denúncia"
                android:textColor="#1A3A5C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/tipoDenuncia"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:elevation="2dp"
                android:entries="@array/tipos_denuncia"/>

            <!-- DESCRIÇÃO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descrição"
                android:textColor="#1A3A5C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/descricaoDenuncia"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="#FFFFFF"
                android:gravity="top"
                android:hint="Descreva o problema encontrado..."
                android:inputType="textMultiLine"
                android:padding="14dp"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:elevation="2dp" />

            <!-- LOCALIZAÇÃO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Localização"
                android:textColor="#1A3A5C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        app:srcCompat="@drawable/outline_add_location_24" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Endereço da denúncia"
                        android:textColor="#1A3A5C"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/localizacao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Nenhuma localização selecionada"
                    android:textColor="#5E6B78"
                    android:textSize="14sp" />

                <!--
                    Mini-mapa de preview.
                    O toque é bloqueado no Activity (setOnTouchListener retorna true),
                    impedindo que o ScrollView "suba" ao arrastar sobre o mapa.
                -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mapPreviewCard"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="14dp"
                    android:visibility="gone"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp">

                    <org.osmdroid.views.MapView
                        android:id="@+id/mapPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                </com.google.android.material.card.MaterialCardView>

                <!-- BOTÕES -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonLocalAtual"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="📍 Minha localização"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        app:backgroundTint="#1A3A5C"
                        app:cornerRadius="14dp" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="wrap_content"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonSelecionarMapa"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="🗺 Selecionar"
                        android:textAllCaps="false"
                        android:textColor="#1A3A5C"
                        android:textSize="12sp"
                        app:backgroundTint="#EAF1F8"
                        app:cornerRadius="14dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- FOTO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Adicionar foto"
                android:textColor="#1A3A5C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp"
                app:strokeColor="#DCE6F0"
                app:strokeWidth="1dp">

                <!--
                    FrameLayout permite sobrepor o botão de remoção (X)
                    no canto superior direito da foto sem precisar de
                    layouts aninhados complexos.
                -->
                <FrameLayout
                    android:id="@+id/imageContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#FFFFFF">

                    <!-- Imagem: ocupa o card inteiro quando selecionada -->
                    <ImageView
                        android:id="@+id/imagePreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="#EEF3F8"
                        android:padding="40dp" />

                    <!--
                        Hint central — visível enquanto não há foto.
                        Fica sobre a ImageView mas não bloqueia o toque
                        (clickable=false); o clique vai para imageContainer.
                    -->
                    <LinearLayout
                        android:id="@+id/imageHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="24dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="false"
                        android:focusable="false">

                        <TextView
                            android:id="@+id/textSelecionarImagem"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toque para adicionar uma foto"
                            android:textColor="#1A3A5C"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Galeria ou câmera"
                            android:textColor="#7A8A99"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!--
                        Botão de remover foto — aparece no canto superior
                        direito somente quando uma foto está selecionada.
                        Fundo circular semitransparente para boa leitura
                        sobre qualquer imagem.
                    -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonRemoverFoto"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="10dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:text="✕"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:visibility="gone"
                        app:backgroundTint="#CC000000"
                        app:cornerRadius="18dp"
                        app:strokeWidth="0dp" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTÃO INFERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/enviarDenuncia"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🚀 Enviar denúncia"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#1A3A5C"
            app:cornerRadius="14dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>