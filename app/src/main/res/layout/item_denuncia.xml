<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título"
            android:textColor="#1A3A5C"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- DESCRIÇÃO -->
        <TextView
            android:id="@+id/textDescricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Descrição"
            android:textColor="#5F6F81"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp" />

        <!-- STATUS -->
        <LinearLayout
            android:id="@+id/layoutStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#FFF3D6"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp">

            <View
                android:id="@+id/dotStatus"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#F5A623" />

            <TextView
                android:id="@+id/textStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="STATUS"
                android:textColor="#F5A623"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- BOTÃO VER MAIS -->
        <LinearLayout
            android:id="@+id/buttonExpandir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver mais"
                android:textColor="#1A3A5C"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iconExpandir"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="6dp"
                android:src="@android:drawable/arrow_down_float"
                android:tint="#1A3A5C" />

        </LinearLayout>

        <!-- ÁREA EXPANSÍVEL -->
        <LinearLayout
            android:id="@+id/layoutExpandido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- LOCALIZAÇÃO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Localização"
                android:textColor="#1A3A5C"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textEndereco"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Endereço"
                android:textColor="#5F6F81"
                android:textSize="13sp" />

            <!-- MAPA -->
            <org.osmdroid.views.MapView
                android:id="@+id/mapMini"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp" />

            <!-- FOTOS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷 Fotos"
                android:textColor="#1A3A5C"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/layoutFotos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

            <!-- DEVOLUTIVA -->
            <LinearLayout
                android:id="@+id/layoutDevolutiva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8EDF2"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 Resposta da Prefeitura"
                    android:textColor="#1A3A5C"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/textDevolutiva"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F0F8F4"
                    android:padding="12dp"
                    android:text=""
                    android:textColor="#2D6A4F"
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>