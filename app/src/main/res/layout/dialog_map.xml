<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A3A5C"
        android:elevation="6dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="48dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗺 Selecionar localização"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Toque no mapa para marcar a denúncia"
            android:textColor="#D6E4F0"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- MAPA -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapDialog"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="130dp"
        android:layout_marginBottom="90dp"/>

    <!-- BOTÃO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonConfirmarLocalizacao"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="✅ Confirmar localização"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#1A3A5C"
            app:cornerRadius="14dp"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>